generator client {
  provider = "prisma-client-js"
  output   = "../generated"
  runtime  = "bun"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String    @id @default(uuid())
  name      String
  email     String    @unique
  password  String
  createdAt DateTime  @default(now())
  projects  Project[]
}

model Project {
  id          String   @id @default(uuid())
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  userId      String?
  user        User?    @relation(fields: [userId], references: [id])
  sandbox     Sandbox?
  logs        Log[]
}

model Sandbox {
  id           String        @id @default(uuid())
  e2bId        String
  status       SandboxStatus @default(CREATED)
  previewUrl   String?
  s3ArchiveKey String?
  archivedAt   DateTime?
  projectId    String        @unique
  project      Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt    DateTime      @default(now())
  destroyedAt  DateTime?

  @@index([e2bId])
}

enum SandboxStatus {
  CREATED
  RUNNING
  STOPPED
  ARCHIVED
  DESTROYED
}

model Log {
  id        String   @id @default(uuid())
  message   String   @db.Text
  type      LogType
  timestamp DateTime @default(now())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

enum LogType {
  STDOUT
  STDERR
  SYSTEM
}
